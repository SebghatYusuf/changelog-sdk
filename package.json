{
  "name": "changelog-sdk",
  "version": "1.1.3",
  "private": false,
  "type": "module",
  "description": "Framework-agnostic changelog core with Next.js adapter and MongoDB adapter",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "default": "./dist/next/index.js"
    },
    "./mongoose": {
      "types": "./dist/mongoose/index.d.ts",
      "default": "./dist/mongoose/index.js"
    },
    "./nuxt": {
      "types": "./dist/nuxt/index.d.ts",
      "default": "./dist/nuxt/index.js"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "default": "./dist/vue/index.js"
    },
    "./styles": "./dist/styles/changelog-ui.css"
  },
  "sideEffects": [
    "./dist/styles/changelog-ui.css"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && mkdir -p dist/styles && cp lib/changelog-platform/styles/changelog-ui.css dist/styles/changelog-ui.css",
    "sync": "bun run build && cd example && bun install",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "dev": "cd example && bun run dev",
    "type-check": "tsc --noEmit",
    "check:mongo": "node scripts/check-mongodb.js",
    "hash:password": "node scripts/hash-password.js",
    "create:admin": "node scripts/create-admin-user.js",
    "example:install": "cd example && bun install",
    "example:dev": "cd example && bun run dev",
    "example:build": "cd example && bun run build",
    "build:landing": "cd example && bun run export"
  },
  "keywords": ["changelog", "sdk", "framework-agnostic", "next.js", "typescript", "mongodb"],
  "author": "Sebghat Yusuf",
  "license": "MIT",
  "peerDependencies": {
    "next": ">=15.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "vue": ">=3.3.0",
    "ai": ">=4.0.0",
    "@ai-sdk/openai": ">=3.0.0",
    "@ai-sdk/google": ">=3.0.0",
    "ollama-ai-provider-v2": ">=3.0.0",
    "h3": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "@ai-sdk/openai": {
      "optional": true
    },
    "@ai-sdk/google": {
      "optional": true
    },
    "ollama-ai-provider-v2": {
      "optional": true
    },
    "h3": {
      "optional": true
    }
  },
  "dependencies": {
    "mongoose": "^9.1.0",
    "zod": "^4.3.6",
    "bcryptjs": "^3.0.3",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "lucide-react": "^0.468.0",
    "marked": "^15.0.12",
    "dompurify": "^3.2.6"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "h3": "^1.15.4",
    "next": "^16.1.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vue": "^3.4.30",
    "ai": "^6.0.116",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/google": "^3.0.43",
    "ollama-ai-provider-v2": "^3.3.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
