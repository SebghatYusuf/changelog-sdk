# MongoDB Connection
# Get your connection string from https://www.mongodb.com/cloud/atlas
CHANGELOG_MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/changelog?retryWrites=true&w=majority

# Create first admin user with:
# bun run create:admin your-admin@email.com your-password "Admin"

# Optional: allow registration through the UI even after first admin exists
# CHANGELOG_ALLOW_ADMIN_REGISTRATION=true

# AI Configuration
# Options: openai, gemini, ollama
CHANGELOG_AI_PROVIDER=openai

# OpenAI Configuration (if using OpenAI)
# Get from https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-your-key-here

# Google Gemini Configuration (if using Gemini)
# Get from https://makersuite.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key

# Ollama Configuration (if using local Ollama)
# Default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# Optional: Rate limiting for AI calls (per minute)
CHANGELOG_RATE_LIMIT=10

# Node Environment
NODE_ENV=development
